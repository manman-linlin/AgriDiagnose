# 复制为 .env 并填入真实值，.env 不会被提交到 Git

# 硅基流动（SiliconFlow）控制台 -> API 密钥
LLM_API_KEY=

# 需要选择支持图片输入的视觉模型（多模态），例如：
#   Qwen/Qwen3-VL-8B-Instruct   （默认，速度快）
#   Qwen/Qwen3-VL-32B-Instruct  （效果更好，更慢）
# 具体可用模型以硅基流动模型广场 / GET https://api.siliconflow.cn/v1/models 为准
LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 换供应商时改这里即可（需兼容 OpenAI chat/completions 协议）
# LLM_BASE_URL=https://api.siliconflow.cn/v1/chat/completions

# AGENT_CONFIDENCE_THRESHOLD=80

# 大模型请求超时（秒），默认 90。部分"思考模型"处理图片+长JSON生成较慢，
# 遇到 Read timed out 报错可以调更大；纯文本快速模型可以调小
# AGENT_REQUEST_TIMEOUT=90
